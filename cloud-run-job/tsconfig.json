{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "node16",
    "moduleResolution": "node16",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": false,
    "outDir": "../dist",
    "rootDir": ".."
  },
  "include": ["../cloud-run-job/**/*"],
  "exclude": ["../node_modules", "../.next", "../dist"]
}
